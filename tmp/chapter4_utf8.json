{
  "value": {
    "content": "\u7bc0 \u76ee \u958b \u59cb \u524d \u8acb \u5e6b \u6211 \u5011 \u8a02 \u95b1 \u958b \u555f \u5c0f \u9234 \u943a \u4f60 \u6210 \u8457 \u5a01 \u56b4 \u7684 \u8072 \u97f3 \u5341 \u5206 \u7684 \u6709 \u6b63 \u8cac \u529b \u5c0d \u65b9 \u4e00 \u807d \u5230 \u4ee5 \u5f8c \u99ac \u4e0a \u5c31 \u628a \u69cd \u653e \u4e0b \u4f86 \u4e86 \u653e \u5230 \u5730 \u4e0a \u7136 \u5f8c \u4e26 \u8209 \u8d77 \u624b \u8ddf \u4f60 \u8aaa \u4f60 \u5011 \u597d \u4f60 \u5011 \u597d \u6211 \u5011 \u525b \u525b \u4ee5 \u70ba \u4f60 \u5011 \u662f \u52d5 \u7269 \u9084 \u597d \u4f60 \u5011 \u6709 \u558a \u4e86 \u4e00 \u8072 \u6211 \u5011 \u624d \u767c \u73fe \u539f \u4f86 \u4f60 \u5011 \u662f \u4eba \u554a \u4f60 \u5011 \u770b \u5230 \u524d \u65b9 \u7de9 \u7de9 \u8d70 \u51fa \u4f86 \u7684 \u4eba \u5f71 \u4e00 \u5927 \u4e00 \u5c0f \u54e6 \u9084 \u662f \u5f88 \u5371 \u96aa \u5c0d \u554a \u7121 \u9ede \u5c0d \u554a \u4ed6 \u5011 \u5169 \u500b \u4eba \u8d70 \u5230 \u4f60 \u5011 \u9762 \u524d \u8ddf \u4f60 \u5011 \u89aa \u5207 \u7684 \u6253 \u62db \u547c \u4f60 \u597d \u6211 \u53eb \u505a \u52de \u751f \u6211 \u662f \u4e00 \u500b \u7375 \u4eba \u5f9e \u6b63 \u5916 \u904e \u4f86 \u7684 \u90a3 \u9019 \u662f \u6211 \u7684 \u5152 \u5b50 \u4ed6 14 \u6b72 \u53eb \u55ac \u6cbb \u6211 \u5011 \u662f \u4f86 \u9019 \u88e1 \u6253 \u7375 \u7684 \u807d \u8aaa \u9019 \u88e1 \u7684 \u68ee \u6797 \u88e1 \u9762 \u5176 \u5be6 \u6709 \u5f88 \u591a \u883b \u4e0d \u932f \u7684 \u7375 \u7269 \u96d6 \u7136 \u807d \u8aaa \u6700 \u8fd1 \u88e1 \u9762 \u662f \u6709 \u5de5 \u7a0b \u4f46 \u5916 \u570d \u9084 \u662f \u883b \u503c \u5f97 \u53bb \u6253 \u7375 \u7684 \u9664 \u4e86 \u6211 \u5011 \u4ee5 \u5916 \u554a \u9084 \u6709 \u6211 \u5011 \u7684 \u9130 \u5c45 \u5e03 \u723e \u8ddf \u4ed6 \u7684 \u5c0f \u5b69 \u963f \u745f \u4e5f \u662f \u6211 \u5011 \u90fd \u662f \u5f9e \u6ce2 \u58eb \u9813 \u4f86 \u7684 \u90a3 \u6211 \u5011 \u4e5f \u60f3 \u8aaa \u5b69 \u5b50 \u5e74 \u7d00 \u5c0f \u56e0 \u70ba \u6211 \u5011 \u5c0d \u6253 \u7375 \u90fd \u5f88 \u6709 \u8208 \u8da3 \u554a \u6211 \u5011 \u4e5f \u60f3 \u63d0 \u65e9 \u6559 \u4ed6 \u5011 \u600e \u9ebc \u6253 \u7375 \u90a3 \u4f60 \u5011 \u77e5 \u9053 \u9019 \u88e1 \u6700 \u8fd1 \u6709 \u53cd \u7d81 \u67b6 \u98ef \u51fa \u73fe \u8001 \u751f \u807d \u5230 \u4f60 \u8b1b \u7d81 \u67b6 \u98ef \u4ed6 \u5f88 \u9a5a \u8a1d \u4ed6 \u8a8d \u4e86 \u4e00 \u4e0b \u7136 \u5f8c \u5927 \u8072 \u7684 \u8aaa \u4ec0 \u9ebc \u9019 \u88e1 \u6709 \u7d81 \u67b6 \u98ef \u6211 \u5011 \u4e0d \u77e5 \u9053 \u554a \u6211 \u7528 \u5fc3 \u7406 \u5b78 \u5c31 \u770b \u6c92 \u6709 \u8aaa \u8a71 \u9019 \u662f \u591a \u5c11 \u53c8 \u4f60 \u770b \u4e0d \u592a \u51fa \u4f86 \u4ed6 \u5011 \u5169 \u500b \u4ed6 \u662f \u4e0d \u662f \u6709 \u5728 \u8aaa \u8b0a \u9019 \u6709 \u5fc3 \u5b78 \u7684 \u6211 \u4e5f \u6709 \u90a3 \u6211 \u4e5f \u554a 53 \u6c92 \u904e \u56e0 \u70ba \u73fe \u5834 \u60c5 \u6cc1 \u9084 \u883b \u7dca \u5f35 \u7684 \u6240 \u4ee5 \u4f60 \u5011 \u5f88 \u96e3 \u770b \u5f97 \u51fa \u4f86 \u4ed6 \u5230 \u5e95 \u6709 \u6c92 \u6709 \u5728 \u8aaa \u8a71 \u6709 \u5176 \u4ed6 \u4eba \u8981 \u55ce \u96d6 \u7136 \u6211 \u53ea \u6709 30 \u4f60 \u4e5f \u53ef \u4ee5 \u8aaa \u670d \u5c0d \u554a \u4ed6 \u4ec0 \u9ebc \u6211 \u4ed6 \u8aaa \u6700 \u597d \u8aaa \u5be6 \u8a71 \u4f60 \u90a3 \u5927 \u903c \u54e5 \u4f60 \u4e0d \u4f86 \u7b49 \u4e00 \u4e0b \u53ef \u4ee5 \u554a \u7b49 \u4ed6 \u5148 \u81ea \u5df1 \u5148 \u4e0a 56 \u8aaa \u6211 \u5148 \u5a01 \u5687 \u5427 \u4e0d \u884c \u6211 \u8001 \u54e6 \u6211 \u4f86 \u5a01 \u6709 \u9ede \u5f37 \u6211 \u5728 \u5a01 \u5687 709092 \u9019 \u597d \u96e3 \u54e6 \u6709 \u53ef \u4ee5 \u770b \u52d5 \u7684 \u8a71 \u4f60 \u544a \u5e95 \u77e5 \u9084 \u4e0d \u77e5 \u6211 \u5011 \u771f \u7684 \u4e0d \u77e5 \u9053 \u4ec0 \u9ebc \u7d81 \u67b6 \u6211 \u5011 \u662f \u883b \u4e45 \u4ee5 \u524d \u6211 \u5011 \u5927 \u6982 \u662f \u4e09 \u56db \u5929 \u524d \u9032 \u4f86 \u7684 \u6211 \u5011 \u4f86 \u9019 \u908a \u53ea \u6709 \u4e09 \u5929 \u6211 \u5011 \u6c92 \u6709 \u807d \u8aaa \u904e \u4ec0 \u9ebc \u7d81 \u67b6 \u98ef \u771f \u7684 \u90a3 \u4f60 \u53e6 \u5916 \u4e00 \u500b \u4f60 \u8aaa \u4f60 \u8ab0 \u4e5f \u9032 \u4f86 \u6211 \u6211 \u7684 \u9130 \u5c45 \u8ca8 \u5152 \u90a3 \u4ed6 \u5011 \u5728 \u54ea \u6211 \u5011 \u662f \u60f3 \u8981 \u5728 \u5916 \u9762 \u6253 \u7375 \u800c \u5df2 \u554a \u53ef \u662f \u4ed6 \u970d \u723e \u8ddf \u6211 \u8b1b \u8aaa \u7537 \u5f97 \u90fd \u4f86 \u9019 \u88e1 \u4e86 \u4ed6 \u5011 \u60f3 \u8981 \u5f80 \u88e1 \u9762 \u8d70 \u6240 \u4ee5 \u4ed6 \u5011 \u662f \u6709 \u5169 \u500b \u4eba \u55ce \u5c31 \u970d \u723e \u8ddf \u4ed6 \u7684 \u5152 \u5b50 \u963f \u745f \u90a3 \u4f60 \u5011 \u5728 \u9019 \u908a \u5f85 \u90a3 \u9ebc \u4e45 \u6709 \u767c \u751f \u4ec0 \u9ebc \u5947 \u602a \u7684 \u4e8b \u6216 \u807d \u5230 \u4ec0 \u9ebc \u5947 \u602a \u7684 \u8072 \u60f3 \u56e0 \u70ba \u90a3 \u6bb5 \u6642 \u9593 \u4f3c \u4e4e \u6709 \u69cd \u6230 \u5728 \u5916 \u570d \u767c \u751f \u4f60 \u5011 \u90fd \u6c92 \u6709 \u807d \u5230 \u4efb \u4f55 \u8072 \u60f3 \u55ce \u6211 \u5011 \u6709 \u807d \u5230 \u4e00 \u4e9b \u5435 \u96dc \u7684 \u8072 \u97f3 \u554a \u90a3 \u500b \u6642 \u5019 \u6211 \u5011 \u4ee5 \u70ba \u662f \u5176 \u4ed6 \u7375 \u4eba \u5728 \u6253 \u7375 \u90a3 \u90a3 \u500b \u8349 \u96dc \u7684 \u8072 \u97f3 \u5f80 \u54ea \u908a \u53bb \u4e86 \u4f60 \u6709 \u8a18 \u5f97 \u55ce \u6211 \u6211 \u60f3 \u4e00 \u4e0b \u5c31 \u662f \u5f80 \u6b63 \u4e0a \u90a3 \u500b \u65b9 \u5411 \u554a \u90a3 \u500b \u6b63 \u4e0a \u7684 \u65b9 \u5411 \u6709 \u4e00 \u4e9b \u8072 \u97ff \u554a \u5927 \u6982 \u662f \u6628 \u5929 \u5427 \u6628 \u5929 \u597d \u50cf \u6709 \u807d \u5230 \u5f88 \u591a \u751f \u7684 \u69cd \u97ff \u6211 \u5011 \u9084 \u5728 \u60f3 \u8aaa \u662f \u4e0d \u662f \u6709 \u7375 \u4eba \u5728 \u8ffd \u8e2a \u7375 \u7269 \u6c92 \u6709 \u6253 \u4e2d \u90a3 \u90a3 \u4f60 \u8aaa \u5176 \u4ed6 \u5730 \u65b9 \u7684 \u8a71 \u6709 \u7684 \u6642 \u5019 \u6211 \u6703 \u807d \u5230 \u4e00 \u4e9b \u5361 \u8eca \u7684 \u8072 \u97f3 \u554a \u5728 \u6cbf \u8457 \u5411 \u5c0f \u8def \u5317 \u65b9 \u7684 \u90a3 \u500b \u6c34 \u5eab \u90a3 \u88e1 \u597d \u50cf \u6709 \u4e00 \u4e9b \u5361 \u8eca \u7684 \u8072 \u97f3 \u90a3 \u6211 \u89ba \u5f97 \u4f60 \u53ef \u80fd \u56e0 \u70ba \u6700 \u8fd1 \u9019 \u5df2 \u7d93 \u958b \u59cb \u5c01 \u9396 \u73fe \u7136 \u53ef \u80fd \u5e36 \u5b69 \u5b50 \u5148 \u51fa \u53bb \u5728 \u9019 \u88e1 \u6709 \u9ede \u5371 \u96aa \u90a3 \u5361 \u8eca \u4e0a \u9762 \u4f60 \u6709 \u8a3b \u610f \u5230 \u6211 \u5011 \u53ea \u6709 \u807d \u5230 \u5361 \u8eca \u7684 \u8072 \u97f3 \u6211 \u53ef \u7528 \u8aaa \u670d \u8aaa \u670d \u4ed6 \u5011 \u52a0 \u5165 \u6211 \u4f60 \u8981 \u904e \u4e00 \u500b \u6975 \u96e3 \u7684 \u8aaa \u670d \u56e0 \u70ba \u4ed6 \u5e36 \u8457 \u5b69 \u5b50 \u591a \u5169 \u500b \u4eba \u5169 \u628a \u69cd \u4e0d \u932f \u5427 \u4f60 \u60f3 \u8981 \u600e \u9ebc \u5439 \u670d \u5443 \u5c31 \u662f \u6211 \u89ba \u5f97 \u9019 \u9019 \u5730 \u65b9 \u6709 \u7d81 \u532a \u592a \u5371 \u96aa \u4e86 \u6211 \u89ba \u5f97 \u4f60 \u5011 \u53ef \u8ddf \u6211 \u5011 \u4e00 \u8d77 \u884c \u52d5 \u56e0 \u70ba \u4f60 \u5e36 \u8457 \u5b69 \u5b50 \u842c \u4e00 \u771f \u7684 \u9047 \u5230 \u7d81 \u532a \u7684 \u8a71 \u6211 \u89ba \u5f97 \u4f60 \u5011 \u53ef \u80fd \u6703 \u9047 \u5230 \u5371 \u96aa \u5c31 \u4e0d \u5982 \u52a0 \u5165 \u6211 \u5011 \u5c31 \u662f \u8ddf \u6211 \u5011 \u4e00 \u8d77 \u884c \u52d5 \u9019 \u6a23 \u5b50 \u90a3 \u6211 \u5011 \u9019 \u908a \u525b \u597d \u6709 \u5973 \u670d \u6211 \u53ef \u4ee5 \u7167 \u6599 \u4f60 \u5152 \u5b50 \u7684 \u751f \u6d3b \u559c \u5c45 \u9019 \u6a23 \u6240 \u4ee5 \u4f60 \u5011 \u662f \u4f86 \u505a \u4ec0 \u9ebc \u7684 \u5c31 \u662f \u4f86 \u6253 \u9632 \u532a \u4e86 \u6211 \u5011 \u8981 \u89e3 \u6551 \u90a3 \u500b \u5bcc \u8c6a \u5973 \u5152 \u56e0 \u70ba \u5973 \u5152 \u88ab \u7d81 \u532a \u7d66 \u731b \u9032 \u6240 \u4ee5 \u9019 \u4f4d \u5148 \u751f \u6211 \u4e0d \u662f \u5f88 \u78ba \u5b9a \u6211 \u6211 \u8aaa \u7684 \u5c0d \u4e0d \u5c0d \u56e0 \u70ba \u4f60 \u5011 \u7adf \u7136 \u662f \u4f86 \u627e \u7d81 \u532a \u7684 \u90a3 \u770b \u8d77 \u4f86 \u532a \u662f \u5f80 \u68ee \u6797 \u88e1 \u9762 \u8dd1 \u7684 \u5c0d \u4e0d \u5c0d \u90a3 \u6211 \u5011 \u61c9 \u8a72 \u5f80 \u5916 \u9762 \u8d70 \u61c9 \u8a72 \u662f \u6bd4 \u8f03 \u5b89 \u5168 \u7684 \u5427 \u6c38 \u5a01 \u9db4 \u4f60 \u8a71 \u4e0d \u8981 \u9019 \u9ebc \u591a \u8ddf \u6211 \u5011 \u4e00 \u8d77 \u8d70 \u5c31 \u5c0d \u4e86 \u5531 \u5b50 \u4e86 \u4ed6 \u4f60 \u70ba \u4ec0 \u9ebc \u6703 \u4ec0 \u9ebc \u4e00 \u8981 \u4ed6 \u8ddf \u4f60 \u8d70 \u6211 \u89ba \u5f97 \u5169 \u628a \u69cd \u4e5f \u883b \u5b89 \u5168 \u7684 \u4f60 \u5a01 \u53eb \u4ed6 \u628a \u69cd \u7d66 \u4f60 \u554a \u5c0d \u4eca \u78b0 \u4e86 \u65af \u7279 \u4e00 \u4e0b \u65af \u79d1 \u7279 \u6211 \u5011 \u9084 \u662f \u8b93 \u4ed6 \u8d70 \u597d \u4e86 \u7562 \u7adf \u9019 \u500b \u5730 \u65b9 \u4e0d \u9069 \u5408 \u8b93 \u4ed6 \u5011 \u7e7c \u7e8c \u5f85 \u53ef \u4ee5 \u53ea \u7559 \u4e00 \u628a \u69cd \u4e00 \u628a \u69cd \u7d66 \u6211 \u5011 \u7d66 \u4ed6 \u4e00 \u628a \u69cd \u6d3b \u6ec5 \u4e0d \u7528 \u670d \u6211 \u7528 \u670d \u5c31 \u89ba \u5f97 \u8aaa \u4e0d \u7136 \u56e0 \u70ba \u6211 \u5011 \u73fe \u5728 \u6253 \u4f46 \u662f \u6211 \u5011 \u6d3b \u529b \u4e0d \u8db3 \u60f3 \u8aaa \u4f60 \u5011 \u6709 \u628a \u69cd \u4e0d \u77e5 \u9053 \u53ef \u4e0d \u53ef \u4ee5 \u7d66 \u6211 \u5011 \u4e00 \u628a \u69cd \u5c31 \u662f \u8b93 \u6211 \u5011 \u9806 \u5229 \u80fd \u5920 \u628a \u5bcc \u8c6a \u7684 \u5973 \u5152 \u6551 \u56de \u4f86 \u6211 \u5011 \u6703 \u5206 \u4f60 \u5011 \u5c31 \u662f \u4e00 \u9ede \u734e \u91d1 \u9019 \u6a23 \u5b50 \u55ef \u6211 \u8981 \u600e \u9ebc \u53ef \u4ee5 \u76f8 \u4fe1 \u4eba \u7576 \u7136 \u6211 \u9019 \u6a23 \u807d \u5404 \u4f4d \u4e5f \u90fd \u662f \u6b63 \u7fa9 \u4e4b \u4e8b \u554a \u6211 \u4e5f \u4e0d \u662f \u5728 \u61f7 \u7591 \u5404 \u4f4d \u4f46 \u9019 \u628a \u69cd \u7562 \u7adf \u662f \u6211 \u7238 \u7238 \u7559 \u7d66 \u6211 \u7684 \u4f60 \u5011 \u8aaa \u6703 \u7d66 \u6211 \u9322 \u4e5f \u53ef \u4ee5 \u90a3 \u6211 \u8981 \u600e \u9ebc \u76f8 \u4fe1 \u4f60 \u6703 \u9084 \u6211 \u6211 \u662f \u6b63 \u4e0a \u7684 \u6cd5 \u5b98 \u4f60 \u5011 \u5c31 \u53ef \u4ee5 \u4f86 \u6cd5 \u9662 \u4f86 \u627e \u6211 \u8acb \u904e \u8aaa \u670d \u771f \u7684 \u4e0d \u932f \u6cd5 \u5b98 \u76f4 \u63a5 \u597d \u7528 \u904e \u9019 \u6a23 \u904e \u4e86 \u597d \u52de \u751f \u807d \u4e86 \u4f60 \u7684 \u8a71 \u7136 \u5f8c \u518d \u52a0 \u4e0a \u4f60 \u4eae \u51fa \u4e86 \u6cd5 \u5b98 \u7684 \u57f7 \u6cd5 \u4eba \u54e1 \u7684 \u8eab \u4efd \u5c0d \u4ed6 \u60f3 \u5728 \u9019 \u500b \u5371 \u6a5f \u7684 \u6642 \u5019 \u4e5f \u672a \u5e38 \u4e0d \u53ef \u4ed6 \u5c31 \u628a \u4ed6 \u7684 \u69cd \u4ea4 \u7d66 \u4f60 \u90a3 \u5230 \u6642 \u5019 \u4f60 \u51fa \u4f86 \u4e00 \u5b9a \u8981 \u9084 \u7d66 \u6211 \u9019 \u628a \u7bb1 \u5c0d \u6211 \u5f88 \u91cd \u8981 \u662f \u6c92 \u6709 \u554f \u984c \u8b1d \u8b1d \u4f60 \u7684 \u5927 \u529b \u4e4b \u5927 \u54e5 \u5168 \u9019 \u9ede \u554a \u6211 \u4e0d \u7528 \u82b1 \u9322 \u5c31 \u6709 \u5566 \u9019 \u5ee2 \u7269 \u5c31 \u6703 \u6436 \u5225 \u4eba \u7684 \u6771 \u897f \u4e0d \u6127 \u662f \u90a3 \u5404 \u4f4d \u5404 \u4f4d \u52c7 \u58eb \u90a3 \u6211 \u5011 \u73fe \u5728 \u662f \u4e0d \u662f \u53ef \u4ee5 \u5148 \u96e2 \u958b \u4e86 \u5462 \u6c92 \u6709 \u554f \u984c \u884c \u597d \u597d \u597d \u90a3 \u4f60 \u6709 \u5403 \u7684 \u55ce \u53ef \u4ee5 \u7559 \u9ede \u7d66 \u6211 \u55ce \u4f60 \u8981 \u5148 \u505a \u4ec0 \u9ebc \u6771 \u897f \u554a \u597d \u4f60 \u7761 \u670d \u591a \u5c11 \u4f60 \u5011 \u662f \u8d85 \u904e \u5206 \u7684 \u4f60 \u60f3 \u4f60 \u9084 \u5e79 \u4e8c \u4e09 \u9019 \u4f4d \u58ef \u4e8b \u554a \u6211 \u5011 \u81ea \u5df1 \u7684 \u98df \u7269 \u5176 \u5be6 \u4e5f \u4e0d \u5920 \u56e0 \u70ba \u6211 \u6c92 \u6709 \u9810 \u8a08 \u8981 \u5728 \u88e1 \u9762 \u5f85 \u5f88 \u4e45 \u6240 \u4ee5 \u6211 \u5011 \u4e5f \u4e5f \u8981 \u51fa \u53bb \u5176 \u5be6 \u4e5f \u5dee \u4e0d \u591a \u4e86 \u53ef \u80fd \u6c92 \u6709 \u8fa6 \u6cd5 \u7d66 \u4f60 \u4f60 \u770b \u6211 \u9084 \u6709 \u5b69 \u5b50 \u8981 \u990a \u597d \u7684 \u4e0d \u904e \u6211 \u6709 \u4e00 \u4ef6 \u4e8b \u60c5 \u662f \u5f88 \u60f3 \u8981 \u62dc \u8a17 \u4f60 \u5011 \u7684 \u56e0 \u70ba \u56e0 \u70ba \u7834 \u723e \u8ddf \u963f \u745f \u4ed6 \u5011 \u5f80 \u88e1 \u9762 \u6df1 \u8655 \u8d70 \u4e86 \u90a3 \u7167 \u4f60 \u5011 \u4f86 \u8aaa \u4ed6 \u5011 \u53ef \u80fd \u9047 \u5230 \u5371 \u96aa \u4e86 \u6709 \u6a5f \u6703 \u53ef \u80fd \u9047 \u5230 \u90a3 \u4e9b \u7d81 \u532a \u5982 \u679c \u4f60 \u5011 \u6709 \u770b \u5230 \u970d \u723e \u8ddf \u963f \u745f \u53ef \u4ee5 \u62dc \u8a17 \u4f60 \u5011 \u5c31 \u662f \u8ddf \u4ed6 \u5011 \u8b1b \u5c31 \u662f \u6709 \u5371 \u96aa \u60c5 \u4ed6 \u5011 \u8d95 \u5feb \u51fa \u4f86 \u55ce \u90a3 \u8981 \u7a7f \u4ec0 \u9ebc \u8863 \u670d \u4f60 \u5011 \u7d55 \u5c0d \u4e0d \u6703 \u932f \u8a8d \u4ed6 \u7684 \u90a3 \u500b \u970d \u723e \u5c31 \u662f \u4ed6 \u5e36 \u8457 \u4e00 \u500b \u53c8 \u5927 \u53c8 \u8001 \u7684 \u90a3 \u7a2e \u5fb7 \u514b \u85a9 \u65af \u5dde \u7684 \u725b \u4ed4 \u5e3d \u4f86 \u906e \u63a9 \u554a \u5c0d \u6211 \u5011 \u524d \u5e7e \u5929 \u7684 \u6642 \u5019 \u4e5f \u6709 \u9047 \u5230 \u4e00 \u5c0d \u85dd \u8853 \u5bb6 \u4ed6 \u8aaa \u4ed6 \u5011 \u662f \u6ce2 \u58eb \u9813 \u5927 \u5b78 \u4f86 \u8457 \u7684 \u662f \u70ba \u4e86 \u8981 \u5b8c \u6210 \u4ed6 \u5011 \u7684 \u5beb \u751f \u4f5c \u696d \u8981 \u53bb \u505a \u4e00 \u4e9b \u597d \u50cf \u91ce \u751f \u52d5 \u7269 \u554a \u9084 \u662f \u7f8e \u666f \u7684 \u5beb \u751f \u90a3 \u4f60 \u5011 \u4e5f \u62dc \u8a17 \u4f60 \u5011 \u7559 \u610f \u4e00 \u4e0b \u4ed6 \u5011 \u5e0c \u671b \u4ed6 \u5011 \u9084 \u6c92 \u6709 \u88ab \u9632 \u532a \u6293 \u4f4f \u5e7e \u500b \u4eba \u85dd \u8853 \u8b1b \u4e00 \u500b \u4eba \u6211 \u7576 \u8a18 \u5f97 \u5927 \u6982 \u4e94 \u516d \u500b \u4eba \u5427 \u90a3 \u4f60 \u5011 \u6709 \u770b \u5230 \u83ef \u4eba \u55ce \u6211 \u5011 \u6709 \u4eba \u5728 \u627e \u4eba \u6c92 \u6709 \u770b \u5230 \u4ec0 \u9ebc \u83ef \u4eba \u4f60 \u8aaa \u8ca8 \u723e \u5c31 \u84cb \u4ec0 \u9ebc \u725b \u4ed4 \u5e3d \u906e \u7259 \u5c0d \u5c0d \u4ed6 \u90a3 \u5e3d \u5b50 \u662f \u5f88 \u6d6e \u8a87 \u7684 \u90a3 \u7a2e \u820a \u4e16 \u7684 \u725b \u4ed4 \u5e3d \u4f60 \u6709 \u9ede \u6572 \u624b \u6211 \u6c92 \u6709 \u5404 \u4f4d \u58ef \u4e8b \u9084 \u6709 \u5176 \u4ed6 \u6211 \u5011 \u53ef \u4ee5 \u70ba \u4f60 \u5011 \u7b11 \u8001 \u7684 \u55ce \u8b1d \u8b1d \u4f60 \u54e6 \u4f60 \u53ef \u4ee5 \u8d70 \u4e86 \u8b1d \u8b1d \u6253 \u56de \u53bb \u5427 \u6709 \u770b \u5230 \u4e00 \u5973 \u5b50 \u55ce \u4e00 \u540d \u5973 \u5b50 \u6c92 \u6709 \u6211 \u5011 \u6c92 \u6709 \u6211 \u6c92 \u6709 \u770b \u5230 \u6211 \u4e00 \u8def \u4e0a \u6211 \u525b \u525b \u9047 \u5230 \u7684 \u4eba \u90fd \u8ddf \u4f60 \u8b1b \u4e86 \u9019 \u500b \u52de \u751f \u7684 \u5152 \u5b50 \u55ac \u6cbb \u4ed6 \u5f88 \u660e \u986f \u7684 \u611f \u5230 \u5f88 \u5bb3 \u6015 \u5f88 \u4e0d \u5b89 \u55ef \u4ed6 \u5728 \u65c1 \u908a \u9760 \u8457 \u7236 \u89aa \u7136 \u5f8c \u4e00 \u76f4 \u4e0d \u592a \u6562 \u8aaa \u8a71 \u7136 \u5f8c \u4e00 \u76f4 \u50ac \u51fa \u6211 \u5011 \u53ef \u4ee5 \u8d95 \u5feb \u96e2 \u958b \u4e86 \u55ce \u55ac \u6cbb \u770b \u8d77 \u5f88 \u537b \u4e0d \u5b89 \u5462 \u4f60 \u6709 \u6c92 \u6709 \u4ec0 \u9ebc \u8a71 \u53ef \u4ee5 \u8ddf \u6211 \u5011 \u8b1b \u8aaa \u6211 \u5011 \u53ef \u4ee5 \u5e6b \u4f60 \u55ac \u6cbb \u5462 \u4ed6 \u5c0d \u4f60 \u6c92 \u6709 \u4ec0 \u9ebc \u6212 \u5fc3 \u90a3 \u56e0 \u70ba \u4e5f \u77e5 \u9053 \u4f60 \u662f \u6cd5 \u5b98 \u4ed6 \u5c31 \u4e00 \u4e94 \u4e00 \u6642 \u7684 \u8ddf \u4f60 \u8aaa \u5176 \u5be6 \u6211 \u8ddf \u6211 \u7238 \u7238 \u4f86 \u9019 \u88e1 \u4ee5 \u5f8c \u6bcf \u5929 \u665a \u4e0a \u90fd \u6703 \u505a \u5669 \u5922 \u6240 \u4ee5 \u6211 \u4e5f \u5f88 \u4e0d \u60f3 \u8981 \u518d \u7e7c \u7e8c \u5f85 \u5728 \u9019 \u88e1 \u6211 \u60f3 \u8981 \u8d95 \u5feb \u96e2 \u958b \u7136 \u73fe \u5728 \u807d \u5230 \u6709 \u6436 \u532a \u9084 \u662f \u7d81 \u532a \u5f88 \u53ef \u6015 \u4f60 \u505a \u4ec0 \u9ebc \u5669 \u5922 \u5c0d \u90a3 \u7a2e \u4f60 \u6c92 \u6709 \u904e \u90a3 \u500b \u5167 \u5bb9 \u662f \u4ec0 \u9ebc \u5462 \u5f88 \u53ef \u6015 \u7684 \u5922 \u6211 \u90fd \u5922 \u5230 \u6211 \u5011 \u4e00 \u76f4 \u9006 \u6c34 \u5f88 \u4e0d \u8212 \u670d \u5c31 \u5f88 \u771f \u5be6 \u597d \u50cf \u6211 \u5011 \u771f \u7684 \u8981 \u6b7b \u4e86 \u6211 \u597d \u5e7e \u6b21 \u90fd \u771f \u7684 \u4ee5 \u70ba \u6211 \u8981 \u6b7b \u4e86 \u6b7b \u5728 \u5922 \u88e1 \u9762 \u90a3 \u4f60 \u6709 \u53bb \u904e \u88e1 \u9762 \u7684 \u6e56 \u55ce \u6c92 \u6709 \u90a3 \u500b \u662f \u5f88 \u88e1 \u9762 \u7684 \u5730 \u65b9 \u6211 \u6c92 \u6709 \u8981 \u5f80 \u88e1 \u9762 \u8d70 \u4e86 \u4f60 \u6709 \u60f3 \u904e \u4f60 \u90a3 \u70ba \u4ec0 \u9ebc \u6cc1 \u6c34 \u4e2d \u4e86 \u55ce \u6211 \u8981 \u60f3 \u60f3 \u6709 \u7684 \u6642 \u5019 \u6211 \u662f \u7ad9 \u5728 \u6e56 \u908a \u597d \u50cf \u6709 \u4ec0 \u9ebc \u6771 \u897f \u7136 \u5f8c \u7b49 \u6211 \u56de \u904e \u795e \u4f86 \u7684 \u6642 \u5019 \u6211 \u5c31 \u8d70 \u5230 \u6e56 \u7684 \u5f80 \u6e56 \u88e1 \u9762 \u8d70 \u53bb \u7136 \u5f8c \u6211 \u4e00 \u500b \u4e0d \u7a69 \u5c31 \u88ab \u62d6 \u4e86 \u4e0b \u53bb \u62d6 \u6211 \u6211 \u9019 \u8b80 \u66f8 \u9928 \u6709 \u770b \u5230 \u9019 \u6771 \u897f \u61c9 \u8a72 \u53ef \u4ee5 \u8b1b \u5427 \u6211 \u4e4b \u524d \u8b80 \u66f8 \u9928 \u653e \u904e \u8cc7 \u6599 \u554a \u5c31 \u662f \u4ed6 \u5011 \u5728 \u90a3 \u908a \u6709 \u5efa \u6c34 \u5eab \u4fee \u6c34 \u5eab \u56e0 \u70ba \u4fee \u6709 \u98a8 \u96aa \u6240 \u7db2 \u8aaa \u90a3 \u6642 \u5019 \u6703 \u6b7b \u5f88 \u591a \u4eba \u4e0d \u60f3 \u8aaa \u4e0d \u6703 \u662f \u90a3 \u88e1 \u771f \u7684 \u662f \u6709 \u4ec0 \u9ebc \u4ed6 \u6211 \u767c \u5230 \u4e00 \u500b \u8a0a \u606f \u5c31 \u662f \u8aaa \u4ed6 \u4ee5 \u524d \u90a3 \u908a \u5c31 \u5357 \u5317 \u6230 \u722d \u561b \u7136 \u5f8c \u5c31 \u662f \u4ec0 \u9ebc \u5c31 \u662f \u4ed6 \u5011 \u90a3 \u6642 \u5019 \u5931 \u6557 \u5c31 \u6703 \u5f9e \u8eb2 \u5230 \u6df1 \u88e1 \u9762 \u7136 \u5f8c \u56de \u5230 \u52a0 \u62ff \u5927 \u9019 \u6a23 \u5b50 \u7136 \u90a3 \u908a \u662f \u4e0d \u662f \u8eb2 \u4e86 \u6703 \u6709 \u5f88 \u591a \u600e \u9ebc \u8b1b \u5175 \u5c0d \u554a \u9019 \u88e1 \u4e5f \u6709 \u807d \u8aaa \u662f \u8aaa \u6709 \u5730 \u5b89 \u4eba \u4e4b \u524d \u5728 \u90a3 \u908a \u4e5f \u4e0d \u6703 \u53bb \u9760 \u8fd1 \u90a3 \u500b \u9019 \u88e1 \u5c31 \u6709 \u5b89 \u4eba \u4f60 \u53ef \u4ee5 \u76f4 \u63a5 \u554f \u6211 \u5011 \u7684 \u90e8 \u843d \u78ba \u5be6 \u90e8 \u843d \u6709 \u9019 \u6a23 \u7684 \u50b3 \u8aaa \u6216 \u9019 \u6a23 \u6b77 \u53f2 \u5c0d \u6211 \u5011 \u90e8 \u843d \u7684 \u5c31 \u662f \u544a \u8a34 \u6211 \u5011 \u8aaa \u6211 \u5011 \u65cf \u4eba \u7d55 \u5c0d \u4e0d \u80fd \u53bb \u54ea \u88e1 \u9023 \u4f60 \u81ea \u5df1 \u662f \u9023 \u6211 \u5011 \u65cf \u4eba \u90fd \u4e0d \u80fd \u904e \u53bb \u5c0d \u70ba \u4ec0 \u9ebc \u56e0 \u70ba \u5c31 \u8aaa \u90a3 \u908a \u597d \u50cf \u6703 \u5f88 \u5371 \u96aa \u90a3 \u90a3 \u9019 \u6a23 \u4eca \u5929 \u4f60 \u80fd \u53bb \u90a3 \u500b \u70ba \u6709 \u9322 \u5f97 \u885d \u5c0d \u4e0d \u5c0d \u56e0 \u70ba \u6211 \u6c92 \u60f3 \u53bb \u770b \u770b \u70ba \u4ec0 \u9ebc \u6211 \u5011 \u7684 \u4e3b \u9577 \u6703 \u544a \u8a34 \u6211 \u5011 \u8aaa \u5b8c \u5168 \u90fd \u4e0d \u80fd \u53bb \u90a3 \u6211 \u4f60 \u4e5f \u4e0d \u660e \u767d \u70ba \u4ec0 \u9ebc \u5c0d \u4f60 \u60f3 \u8981 \u53bb \u8abf \u67e5 \u6240 \u6211 \u60f3 \u53bb \u8abf \u67e5 \u6211 \u662f \u4e3b \u88e1 \u9762 \u7684 \u5e0c \u671b \u6211 \u8981 \u6253 \u7834 \u8ff7 \u6211 \u4ee5 \u524d \u5c31 \u6709 \u89ba \u5f97 \u597d \u5947 \u602a \u70ba \u4ec0 \u9ebc \u8001 \u723a \u8981 \u8b93 \u5c0f \u59d0 \u53bb \u90a3 \u9ebc \u53ef \u6015 \u7684 \u5c0d \u554a \u5bf6 \u8c9d \u5973 \u800c \u4e14 \u6c92 \u6709 \u6c34 \u8b77 \u55ce \u525b \u525b \u8b66 \u9577 \u6709 \u8aaa \u662f \u6709 \u96a8 \u8b77 \u7684 \u53ea \u662f \u56e0 \u70ba \u5c0d \u65b9 \u610f \u5f88 \u5f37 \u554f \u4e00 \u4e0b \u4f60 \u4e4b \u524d \u90fd \u6709 \u966a \u5c0f \u59d0 \u4e00 \u8d77 \u4f86 \u904e \u4f60 \u6709 \u966a \u4ed6 \u6c92 \u6709 \u966a \u5c0f \u59d0 \u4f86 \u904e \u53ef \u662f \u6211 \u6703 \u89ba \u5f97 \u5c0f \u59d0 \u597d \u50cf \u4e5f \u5c31 \u90a3 \u6a23 \u53bb \u597d \u50cf \u56de \u4f86 \u4e5f \u5c31 \u90a3 \u6a23 \u56de \u4f86 \u628a \u62ff \u51fa \u4f86 \u5403 \u5403 \u8b8a \u6211 \u53ef \u4ee5 \u6211 \u53ef \u4ee5 \u770b \u4ed6 \u662f \u771f \u8aaa \u771f \u7684 \u5047 \u7684 \u5c31 \u4ed6 \u6709 \u6c92 \u6709 \u77e5 \u9053 \u66f4 \u591a \u7684 \u8a0a \u606f \u90a3 \u70ba \u4ec0 \u9ebc \u53ea \u6709 \u4f60 \u51fa \u4f86 \u4f60 \u7684 \u8001 \u723a \u77e5 \u9053 \u4f60 \u51fa \u4f86 \u627e \u5c0f \u91d1 \u55ce \u8001 \u723a \u9ed8 \u9ed8 \u7684 \u5728 \u6709 \u554a \u6709 \u770b \u5230 \u4f60 \u662f \u5bb6 \u5ead \u56e0 \u70ba \u6211 \u8ddf \u5c0f \u59d0 \u5f9e \u5c0f \u5c31 \u4e00 \u8d77 \u73a9 \u5566 \u5c0f \u59d0 \u9019 \u6b21 \u9019 \u6a23 \u4e0d \u898b \u6211 \u4e5f \u5f88 \u64d4 \u5fc3 \u55ef \u90a3 \u4f60 \u600e \u9ebc \u6c92 \u6709 \u5e36 \u5176 \u6c34 \u8b77 \u8d77 \u4f86 \u771f \u90a3 \u9ebc \u5371 \u96aa \u6211 \u4e00 \u6211 \u4e00 \u500b \u5973 \u50d5 \u54ea \u6709 \u6c34 \u8b77 \u6703 \u9818 \u6211 \u554a \u597d \u6211 \u60f3 \u554f \u4e0b \u4f60 \u8ddf \u5c0f \u59d0 \u7684 \u95dc \u4fc2 \u662f \u597d \u6211 \u5f9e \u5c0f \u8ddf \u5c0f \u59d0 \u4e00 \u8d77 \u73a9 \u4e00 \u8d77 \u73a9 \u4e0d \u8868 \u611f \u60c5 \u662f \u5f88 \u597d \u55ce \u624d \u80fd \u5920 \u5ac9 \u5992 \u61a4 \u6012 \u4e0d \u5e73 \u4eba \u60f3 \u8981 \u53d6 \u4ee3 \u4ed6 \u7684 \u7684 \u611f \u89ba \u5427 \u6211 \u4ec0 \u9ebc \u6211 \u5e79 \u561b \u53d6 \u904e \u5b9a \u4f60 \u8981 \u904e \u5fc3 \u7406 \u5b78 \u90a3 \u90a3 \u4ed6 \u4e5f \u8981 \u904e \u90a3 \u500b \u5fc3 \u7406 \u5b78 \u591a \u5c11 \u592a \u9ad8 \u4e86 \u5566 \u4f60 \u9019 \u4e00 \u5b9a \u6b7b \u4e86 \u5566 \u53ef \u662f \u6211 \u89ba \u5f97 \u4ed6 \u8aaa \u7684 \u662f \u771f \u7684 96 \u4f60 \u5011 \u90fd \u662f \u5931 \u6557 \u5566 \u90a3 \u4f60 \u5176 \u5be6 \u4e5f \u770b \u4e0d \u51fa \u4f86 \u597d \u5427 \u6211 \u5c31 \u7e7c \u7e8c \u5427 \u7e7c \u7e8c \u7e7c \u7e8c \u6211 \u60f3 \u8981 \u6211 \u60f3 \u8981 \u6500 \u722c \u5230 \u6a39 \u4e0a \u7576 \u5927 \u5bb6 \u90fd \u5728 \u8b1b \u8a71 \u7684 \u6642 \u5019 \u529f \u592b \u9ad8 \u624b \u7684 \u5009 \u865f \u89ba \u5f97 \u60f3 \u8981 \u9019 \u5728 \u81ea \u9ad8 \u9ede \u7a0d \u5fae \u773a \u671b \u4e00 \u4e0b \u80e1 \u90a3 \u908a \u7684 \u5148 \u884c \u6211 \u6500 \u722c \u662f \u597d \u8acb \u6500 \u722c \u6240 \u4ee5 \u4ed6 \u9577 \u597d \u5728 \u5e79 \u561b \u554a \u73fe \u88ab \u5e38 \u770b \u5230 \u4f60 \u7684 \u4e0d \u8981 \u8b93 \u6211 \u5011 \u884c \u4e2d \u5410 \u8def \u597d \u6240 \u4ee5 \u4f60 \u722c \u4e0a \u53bb \u7684 \u6642 \u5019 \u8173 \u8e29 \u6ed1 \u4e86 \u6ed1 \u4e86 \u4e0b \u4f86 \u88ab \u8def \u627e \u5730 \u4e00 \u6ef4 \u8840 \u6211 \u8ddf \u5927 \u5f88 \u602a \u602a \u771f \u5f88 \u5c0d \u7b11 \u662f \u4e9e \u4eba \u8166 \u6211 \u5e6b \u4f60 \u6025 \u6551 \u6025 \u6551 \u6210 \u529f \u54e6 \u6025 \u6551 \u6210 \u529f \u4e86 \u7372 \u5f97 \u4e00 \u9ede \u9664 \u4e86 \u5176 \u4ed6 \u4eba \u90fd \u5728 \u5632 \u8af7 \u4ee5 \u5916 \u5b89 \u4f60 \u5f88 \u8cbc \u5fc3 \u7684 \u70ba \u5012 \u4e0b \u7684 \u5009 \u865f \u9032 \u884c \u4e86 \u5305 \u7d2e \u5009 \u865f \u7ad9 \u8d77 \u4f86 \u9084 \u9019 \u5df1 \u8aaa \u6c92 \u4ec0 \u9ebc \u4e8b \u60c5 \u6211 \u5011 \u4e5f \u6c92 \u95dc \u4fc2 \u4f60 \u4f60 \u5011 \u525b \u525b \u7d93 \u904e \u4e86 \u9019 \u4e00 \u6ce2 \u7684 \u6298 \u9a30 \u73fe \u5728 \u5df2 \u7d93 \u5feb \u8981 \u9032 \u5165 \u4e86 \u5e6b \u7db2 \u4f60 \u5011 \u8981 \u6e96 \u5099 \u7b54 \u98f2 \u4e86 \u4f60 \u5011 \u90fd \u77e5 \u9053 \u554a \u5c24 \u5176 \u662f \u65af \u79d1 \